APP_NAME=skeleton
APP_ENV=production
SCAN_CACHEABLE=false

DB_DRIVER=mysql
DB_READ_HOST=mysql_83
DB_WRITE_HOST=mysql_83
DB_PORT=3306
DB_DATABASE=lms
DB_USERNAME=root
DB_PASSWORD=unimestre
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

REDIS_HOST=redis
REDIS_AUTH=
REDIS_PORT=6379
REDIS_DB=0

ACL_DEBUG_ROUTES=false

SWAGGER_ENABLE=true
SWAGGER_PORT=9500
SWAGGER_URL_PATH=/swagger
SWAGGER_AUTO_GENERATE=true
SWAGGER_SERVER_URL=http://127.0.0.1:9501
APP_VERSION=1.0.0